# Dev: keep these commented so the browser uses same origin (e.g. :8080) and Vite proxies
# /api and /socket.io to the backend. Uncomment only if you intentionally call the API host
# directly (then the Nest server must be running on that port or you get ERR_CONNECTION_REFUSED).
# VITE_API_BASE_URL=http://localhost:3000/api/v1
# VITE_BACKEND_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000
#
# Where Nest listens (default 3000 — must match when proxying):
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000

# Production or when the API is on another host, uncomment and set:
# VITE_API_BASE_URL=https://your-api.example.com/api/v1
# VITE_BACKEND_URL=https://your-api.example.com/api/v1
# VITE_SOCKET_URL=https://your-api.example.com

