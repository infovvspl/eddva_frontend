VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_BACKEND_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000
# Dev: leave API/socket URLs unset so the app uses the same host as the page
# (http://localhost:8080 or http://<your-LAN-IP>:8080). REST goes through Vite
# /api proxy; Socket.IO through /socket.io (see vite.config.ts).
# Where Nest listens (default is fine if API runs on this machine):
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000

# Production or when the API is on another host, uncomment and set:
# VITE_API_BASE_URL=https://your-api.example.com/api/v1
# VITE_BACKEND_URL=https://your-api.example.com/api/v1
# VITE_SOCKET_URL=https://your-api.example.com

